# Z.ai / GLM provider token
# Required when running with --provider glm
# Get your token from Z.ai and set it here, then: source .env
# export NOUMENON_ZAI_TOKEN=your-token-here

# --- Server mode (docker compose) ---

# Required: admin token for managing the server
# Generate with: openssl rand -base64 32
# NOUMENON_TOKEN=change-me-to-a-random-secret

# Optional: webhook secret for GitHub/GitLab push notifications
# NOUMENON_WEBHOOK_SECRET=

# Optional: LLM provider for analyze/ask
# NOUMENON_LLM_PROVIDER=glm
# NOUMENON_LLM_MODEL=sonnet

# Optional: server tuning
# NOUMENON_PORT=7891
# NOUMENON_READ_ONLY=false
# NOUMENON_MAX_ASK_SESSIONS=50
# NOUMENON_MAX_LLM_CONCURRENCY=10
# NOUMENON_POLL_INTERVAL=5
# NOUMENON_LOG_FORMAT=text
