{:name "pure-segments"
 :description "Pure (side-effect-free) code segments"
 :query [:find ?path ?name ?kind
         :where
         [?seg :code/pure? true]
         [?seg :code/name ?name]
         [?seg :code/file ?file]
         [?file :file/path ?path]
         [(get-else $ ?seg :code/kind :unknown) ?kind]]}
