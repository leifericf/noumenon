;; Reusable Datalog rules for the Noumenon knowledge graph.
;; Usage: pass as :rules argument to d/q.

[;; Transitive component dependency — follows :component/depends-on recursively
 [(transitive-dep ?a ?b)
  [?a :component/depends-on ?b]]
 [(transitive-dep ?a ?b)
  [?a :component/depends-on ?mid]
  (transitive-dep ?mid ?b)]

 ;; Directory ancestry — follows :dir/parent recursively
 [(dir-ancestor ?child ?ancestor)
  [?child :dir/parent ?ancestor]]
 [(dir-ancestor ?child ?ancestor)
  [?child :dir/parent ?mid]
  (dir-ancestor ?mid ?ancestor)]

 ;; Co-change: two files changed in the same commit
 [(co-changed ?f1 ?f2 ?commit)
  [?commit :commit/changed-files ?f1]
  [?commit :commit/changed-files ?f2]
  [(!= ?f1 ?f2)]]

 ;; Person who authored commits that changed a file
 [(file-author ?file ?person)
  [?commit :commit/changed-files ?file]
  [?commit :commit/author ?person]]

 ;; File in directory tree — direct
 [(file-in-dir-tree ?file ?dir)
  [?file :file/directory ?dir]]
 ;; File in directory tree — recursive via dir-ancestor
 [(file-in-dir-tree ?file ?dir)
  [?file :file/directory ?child]
  (dir-ancestor ?child ?dir)]

 ;; Segment in directory tree — recursive
 [(segment-in-dir-tree ?seg ?dir)
  [?seg :code/file ?file]
  (file-in-dir-tree ?file ?dir)]

 ;; Commits of a given kind that touched a file
 [(file-kind-commit ?file ?kind ?commit)
  [?commit :commit/changed-files ?file]
  [?commit :commit/kind ?kind]]

 ;; Transitive import — follows :file/imports recursively
 [(transitive-import ?a ?b)
  [?a :file/imports ?b]]
 [(transitive-import ?a ?b)
  [?a :file/imports ?mid]
  (transitive-import ?mid ?b)]

 ;; Test file for source file — test that transitively imports source
 [(test-for-file ?test ?src)
  [?test :file/path ?tpath]
  [(clojure.string/includes? ?tpath "test")]
  (transitive-import ?test ?src)]

 ;; Files in a component
 [(component-file ?comp ?file)
  [?file :arch/component ?comp]]

 ;; Segments in a component
 [(component-segment ?comp ?seg)
  [?seg :code/file ?file]
  [?file :arch/component ?comp]]

 ;; Commits that touched a component
 [(component-commit ?comp ?commit)
  [?commit :commit/changed-files ?file]
  [?file :arch/component ?comp]]

 ;; Import-derived component dependency — live from file/imports graph
 [(import-component-dep ?c1 ?c2)
  [?f1 :file/imports ?f2]
  [?f1 :arch/component ?c1]
  [?f2 :arch/component ?c2]
  [(!= ?c1 ?c2)]]]
