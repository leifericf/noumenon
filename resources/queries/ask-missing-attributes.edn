{:name "ask-missing-attributes"
 :description "Attributes or relationships that ask agents needed but couldn't find — data model gaps"
 :query [:find ?attrs ?question ?repo
         :where
         [?e :ask.session/missing-attributes ?attrs]
         [?e :ask.session/question ?question]
         [(get-else $ ?e :ask.session/repo "") ?repo]]}
