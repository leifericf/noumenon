{:name "complex-hotspots"
 :description "Files that are both high-churn and high-complexity"
 :federation-mode :tombstone-only
 :query [:find ?path ?complexity (count ?commit)
         :where
         [?file :file/path ?path]
         [?file :sem/complexity ?complexity]
         (or [?file :sem/complexity :complex]
             [?file :sem/complexity :very-complex])
         [?commit :commit/changed-files ?file]]}
