{:name "uncalled-segments"
 :description "Source code segments whose name does not appear in any other segment's call-names — excludes tests, data files, and import statements"
 :query [:find ?path ?name ?kind
         :where
         [?seg :code/name ?name]
         [?seg :code/file ?file]
         [?file :file/path ?path]
         [(get-else $ ?seg :code/kind :unknown) ?kind]
         (not [_ :code/call-names ?name])
         ;; Exclude test files — test runners invoke them reflectively
         (not [(clojure.string/starts-with? ?path "test/")])
         (not [(clojure.string/includes? ?path "_test.")])
         (not [(clojure.string/includes? ?path ".test.")])
         (not [(clojure.string/includes? ?path "Test.")])
         ;; Exclude data/config files — loaded via readers, not calls
         (not [(clojure.string/ends-with? ?path ".edn")])
         (not [(clojure.string/ends-with? ?path ".json")])
         (not [(clojure.string/ends-with? ?path ".yml")])
         (not [(clojure.string/ends-with? ?path ".yaml")])
         (not [(clojure.string/ends-with? ?path ".toml")])
         (not [(clojure.string/ends-with? ?path ".xml")])
         (not [(clojure.string/ends-with? ?path ".html")])
         (not [(clojure.string/ends-with? ?path ".css")])
         (not [(clojure.string/ends-with? ?path ".md")])
         ;; Exclude import/include/namespace segments — they are not callable
         (not [(contains? #{:include :namespace} ?kind)])]}
