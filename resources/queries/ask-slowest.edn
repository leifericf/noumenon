{:name "ask-slowest"
 :description "Slowest ask sessions by wall-clock time — identifies expensive questions"
 :query [:find ?question ?dur ?iters ?tokens ?repo
         :where
         [?e :ask.session/question ?question]
         [?e :ask.session/duration-ms ?dur]
         [(get-else $ ?e :ask.session/iterations 0) ?iters]
         [(get-else $ ?e :ask.session/input-tokens 0) ?tokens]
         [(get-else $ ?e :ask.session/repo "") ?repo]]}
