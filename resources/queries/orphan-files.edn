{:name "orphan-files"
 :description "Source code files that neither import nor are imported by any other file — excludes config, data, CI, and doc files"
 :federation-safe? true
 :query [:find ?path
         :where
         [?file :file/path ?path]
         [?file :file/lang _]
         (not [?file :file/imports _])
         (not [_ :file/imports ?file])
         ;; Exclude non-source directories
         (not [(clojure.string/starts-with? ?path "resources/")])
         (not [(clojure.string/starts-with? ?path ".github/")])
         (not [(clojure.string/starts-with? ?path "docs/")])
         (not [(clojure.string/starts-with? ?path "dev/")])
         ;; Exclude data file extensions
         (not [(clojure.string/ends-with? ?path ".edn")])
         (not [(clojure.string/ends-with? ?path ".json")])
         (not [(clojure.string/ends-with? ?path ".yml")])
         (not [(clojure.string/ends-with? ?path ".yaml")])
         (not [(clojure.string/ends-with? ?path ".toml")])
         (not [(clojure.string/ends-with? ?path ".xml")])
         (not [(clojure.string/ends-with? ?path ".html")])
         (not [(clojure.string/ends-with? ?path ".css")])
         (not [(clojure.string/ends-with? ?path ".md")])
         (not [(clojure.string/ends-with? ?path ".txt")])]}
