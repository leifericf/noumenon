[{:db/ident       :prov/confidence
  :db/valueType   :db.type/double
  :db/cardinality :db.cardinality/one
  :db/doc         "LLM confidence score, 0.0–1.0 — asserted on entity (file/code-segment), not on tx"}

 {:db/ident       :prov/model-version
  :db/valueType   :db.type/string
  :db/cardinality :db.cardinality/one
  :db/doc         "Specific LLM model version identifier"}

 {:db/ident       :prov/prompt-hash
  :db/valueType   :db.type/string
  :db/cardinality :db.cardinality/one
  :db/doc         "SHA hash of prompt template used"}

 {:db/ident       :prov/analyzed-at
  :db/valueType   :db.type/instant
  :db/cardinality :db.cardinality/one
  :db/doc         "Timestamp when LLM analysis was performed"}

 {:db/ident       :prov/promoted-from
  :db/valueType   :db.type/ref
  :db/cardinality :db.cardinality/one
  :db/doc         "Donor transaction this analysis was promoted from — set on tx entities when content-addressed promotion copies an analysis from another tx instead of re-running the LLM. Same-DB lookup: the ref points within the recipient's DB. Cross-DB lookup: the donor tx-id is opaque from the recipient's perspective; pair this with :prov/promoted-from-db-name for the breadcrumb"}

 {:db/ident       :prov/promoted-from-db-name
  :db/valueType   :db.type/string
  :db/cardinality :db.cardinality/one
  :db/doc         "Database name of the donor when promotion crossed databases (e.g. trunk DB name when a delta promoted from trunk). Nil for same-DB promotions"}]
