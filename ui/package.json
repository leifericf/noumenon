{
  "name": "noumenon-ui",
  "version": "0.5.1",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "shadow-cljs watch app",
    "portfolio": "shadow-cljs watch portfolio",
    "release": "shadow-cljs release app",
    "electron": "electron .",
    "package": "shadow-cljs release app && electron-builder build"
  },
  "dependencies": {
    "d3-force": "^3.0.0",
    "d3-quadtree": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "electron-updater": "~6.0.0",
    "snabbdom": "3.5.1"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "shadow-cljs": "^2.28.0"
  },
  "build": {
    "appId": "com.noumenon.ui",
    "productName": "Noumenon",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "resources/public/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "publish": {
      "provider": "github",
      "owner": "leifericf",
      "repo": "noumenon"
    }
  }
}
